---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Inicio">
	<header class="fixed top-0 left-0 w-full z-50 transition-all duration-300" id="main-header">
		<nav class="w-full px-6 md:px-12 lg:px-24 py-2 flex justify-between items-center">
			<div class="flex items-center gap-2">
				<img src="/images/logo.png" alt="Fenixx Logo" class="h-28 w-auto object-contain" />
			</div>
			
			<div class="hidden md:flex items-center gap-8 ml-auto">
				<div class="flex items-center gap-6 mr-4">
					<a href="#" class="text-white hover:text-fenix-red-light font-bold transition-colors">Inicio</a>
					<a href="#servicios" class="text-white hover:text-fenix-red-light font-bold transition-colors">Servicios</a>
					<a href="#proyectos" class="text-white hover:text-fenix-red-light font-bold transition-colors">Portafolio</a>
					<a href="#contacto" class="bg-white text-fenix-black px-6 py-2 rounded-full font-bold hover:bg-fenix-red-light hover:text-white transition-all">Contáctanos</a>
				</div>
				<div class="flex items-center gap-4 py-2 border-l border-white/20 pl-6">
					<a href="#" class="text-white hover:text-fenix-red-light transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x"><path d="M4 4l11.733 16h4.267l-11.733 -16z"/><path d="M4 20l6.768 -6.746m2.464 -2.454l6.768 -6.8"/></svg>
					</a>
					<a href="#" class="text-white hover:text-fenix-red-light transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
					</a>
					<a href="#" class="text-white hover:text-fenix-red-light transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-facebook"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
					</a>
					<a href="#" class="text-white hover:text-fenix-red-light transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
					</a>
				</div>
			</div>

			<!-- Mobile Menu Button -->
			<button class="md:hidden text-white">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
				</svg>
			</button>
		</nav>
	</header>

	<main>
		<Hero />
		
		<!-- Placeholder for next sections to allow scrolling and testing header -->
		<section class="h-screen flex items-center justify-center bg-fenix-white text-fenix-black uppercase font-black text-4xl" id="servicios">
			Sección en desarrollo...
		</section>
	</main>
</Layout>

<script>
	const header = document.getElementById('main-header');
	window.addEventListener('scroll', () => {
		if (window.scrollY > 50) {
			header?.classList.add('bg-black/80', 'backdrop-blur-md', 'py-1');
			header?.classList.remove('py-2');
		} else {
			header?.classList.remove('bg-black/80', 'backdrop-blur-md', 'py-1');
			header?.classList.add('py-2');
		}
	});
</script>
