---

<header class="absolute top-0 left-0 w-full z-50 transition-all duration-500 py-2" id="main-header">
  <nav class="w-full px-6 md:px-12 lg:px-24 flex justify-between items-center transition-all duration-500">
    <div class="flex items-center gap-2">
      <img src="/images/logo.png" alt="Fenixx Logo" class="h-24 w-auto object-contain transition-all duration-500 logo-img" />
    </div>
    
    <div class="hidden md:flex items-center gap-8 ml-auto">
      <div class="flex items-center gap-6 mr-4">
        <a href="#" class="nav-link text-white hover:text-[#FC3D03] font-bold text-[14px] transition-colors">Inicio</a>
        <a href="#servicios" class="nav-link text-white hover:text-[#FC3D03] font-bold text-[14px] transition-colors">Servicios</a>
        <a href="#proyectos" class="nav-link text-white hover:text-[#FC3D03] font-bold text-[14px] transition-colors">Portafolio</a>
        <a href="#contacto" class="nav-link text-white hover:text-[#FC3D03] font-bold text-[14px] transition-colors">Contáctanos</a>
      </div>
      <div class="flex items-center gap-4 py-2 border-l border-white/20 pl-6 social-links">
        <a href="#" class="nav-link text-white hover:text-fenix-red-light transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x"><path d="M4 4l11.733 16h4.267l-11.733 -16z"/><path d="M4 20l6.768 -6.746m2.464 -2.454l6.768 -6.8"/></svg>
        </a>
        <a href="#" class="nav-link text-white hover:text-fenix-red-light transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="#" class="nav-link text-white hover:text-fenix-red-light transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-facebook"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="#" class="nav-link text-white hover:text-fenix-red-light transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </a>
      </div>
    </div>

    <!-- Mobile Menu Button -->
    <button class="md:hidden text-white mobile-menu-btn">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
    </button>
  </nav>
</header>

<style>
  /* Estado inicial (en el Hero) */
  #main-header {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 50;
    transition: all 0.5s ease;
    background-color: transparent;
  }

  /* Estado Scrolled (Barra Blanca) */
  #main-header.is-scrolled {
    position: fixed;
    background-color: white;
    padding-top: 0.3rem;
    padding-bottom: 0.3rem;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    animation: slide-down 0.4s ease-out forwards;
  }

  @keyframes slide-down {
    from { transform: translateY(-100%); }
    to { transform: translateY(0); }
  }

  #main-header.is-scrolled .nav-link {
    color: black;
  }

  #main-header.is-scrolled .nav-link:hover {
    color: #FC3D03; /* fenix-red-light */
  }

  #main-header.is-scrolled .logo-img {
    height: 4rem; /* h-16 aproximado */
  }

  #main-header.is-scrolled .social-links {
    border-color: rgba(0, 0, 0, 0.1);
  }

  #main-header.is-scrolled .mobile-menu-btn {
    color: black;
  }
</style>

<script>
  const header = document.getElementById('main-header');
  
  window.addEventListener('scroll', () => {
    if (window.scrollY > 600) {
      header?.classList.add('is-scrolled');
      header?.classList.remove('absolute');
    } else {
      header?.classList.remove('is-scrolled');
      header?.classList.add('absolute');
    }
  });
</script>
