---
---

<section id="contacto" class="py-24 md:py-32 bg-fenix-black relative overflow-hidden">

  <!-- Monumental Background -->
  <div class="absolute top-1/2 left-0 -translate-y-1/2 w-full select-none pointer-events-none overflow-hidden flex justify-center opacity-[0.02]">
    <span class="text-[15vw] font-black text-white uppercase tracking-tighter whitespace-nowrap leading-none">
      CONTACTO
    </span>
  </div>

  <div class="w-full px-6 md:px-12 lg:px-24 relative z-10">

    <!-- Header -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16">
      <div class="lg:col-span-6">
        <span class="text-xs uppercase tracking-[0.3em] text-fenix-red-light font-bold block mb-4">
          Contáctanos
        </span>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-[0.9] tracking-tight">
          ¿Listo para<br/>
          <span class="text-fenix-red-light">optimizar</span> su logística?
        </h2>
      </div>
      <div class="lg:col-span-4 lg:col-start-9 flex items-end">
        <p class="text-white/60 text-base md:text-lg leading-relaxed">
          Cuéntenos sobre su operación y diseñaremos la solución logística que su negocio necesita.
        </p>
      </div>
    </div>

    <!-- Form + Info Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

      <!-- Contact Form -->
      <div class="lg:col-span-7">
        <form class="space-y-6" id="contact-form">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="nombre" class="text-white/50 text-xs uppercase tracking-wider font-bold block mb-2">Nombre</label>
              <input 
                type="text" 
                id="nombre" 
                name="nombre"
                placeholder="Su nombre completo"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder:text-white/30 focus:outline-none focus:border-fenix-red-light transition-colors"
                required
              />
            </div>
            <div>
              <label for="email" class="text-white/50 text-xs uppercase tracking-wider font-bold block mb-2">Email</label>
              <input 
                type="email" 
                id="email" 
                name="email"
                placeholder="correo@empresa.com"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder:text-white/30 focus:outline-none focus:border-fenix-red-light transition-colors"
                required
              />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="telefono" class="text-white/50 text-xs uppercase tracking-wider font-bold block mb-2">Teléfono</label>
              <input 
                type="tel" 
                id="telefono" 
                name="telefono"
                placeholder="+58 (000) 000-0000"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder:text-white/30 focus:outline-none focus:border-fenix-red-light transition-colors"
              />
            </div>
            <div>
              <label for="servicio" class="text-white/50 text-xs uppercase tracking-wider font-bold block mb-2">Servicio de interés</label>
              <select 
                id="servicio" 
                name="servicio"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white/50 focus:outline-none focus:border-fenix-red-light transition-colors appearance-none"
              >
                <option value="">Seleccione un servicio</option>
                <option value="transporte">Transporte Multimodal</option>
                <option value="aduanas">Gestión Aduanera</option>
                <option value="carga">Manejo de Carga</option>
                <option value="equipos">Alquiler de Equipos</option>
                <option value="otro">Otro</option>
              </select>
            </div>
          </div>
          <div>
            <label for="mensaje" class="text-white/50 text-xs uppercase tracking-wider font-bold block mb-2">Mensaje</label>
            <textarea 
              id="mensaje" 
              name="mensaje"
              rows="5"
              placeholder="Describa brevemente su necesidad logística..."
              class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white placeholder:text-white/30 focus:outline-none focus:border-fenix-red-light transition-colors resize-none"
              required
            ></textarea>
          </div>
          <button 
            type="submit"
            class="bg-fenix-red-light hover:bg-fenix-red-dark text-white px-10 py-4 rounded-full font-bold text-lg transition-all duration-300 transform hover:scale-105 shadow-lg shadow-fenix-red-light/20 w-full md:w-auto"
          >
            Enviar solicitud
          </button>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="lg:col-span-4 lg:col-start-9 space-y-8">
        <div>
          <h4 class="text-white font-bold text-lg mb-3">Domicilio Fiscal</h4>
          <p class="text-white/50 text-sm leading-relaxed">
            Av. Raúl Leoni con Avenida Real,<br/>
            Local Nro. S/N, Urb. Industria de Guanta,<br/>
            Guanta, Edo. Anzoátegui. Zona Postal 6014
          </p>
        </div>
        <div>
          <h4 class="text-white font-bold text-lg mb-3">Teléfono</h4>
          <a href="tel:+5804129671098" class="text-white/50 text-sm hover:text-fenix-red-light transition-colors">
            +58 0412 967 1098
          </a>
        </div>
        <div>
          <h4 class="text-white font-bold text-lg mb-3">Email</h4>
          <a href="mailto:info@fenixx.com" class="text-white/50 text-sm hover:text-fenix-red-light transition-colors">
            info@fenixx.com
          </a>
        </div>
        <div>
          <h4 class="text-white font-bold text-lg mb-3">Horario</h4>
          <p class="text-white/50 text-sm leading-relaxed">
            Lunes - Viernes: 8:00am - 5:00pm<br/>
            Sábados: 8:00am - 12:00pm
          </p>
        </div>

        <!-- Social Links -->
        <div class="pt-4 border-t border-white/10">
          <h4 class="text-white font-bold text-lg mb-4">Síguenos</h4>
          <div class="flex gap-4">
            <a href="#" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/60 hover:bg-fenix-red-light hover:border-fenix-red-light hover:text-white transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a href="#" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/60 hover:bg-fenix-red-light hover:border-fenix-red-light hover:text-white transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
            </a>
            <a href="#" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/60 hover:bg-fenix-red-light hover:border-fenix-red-light hover:text-white transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
