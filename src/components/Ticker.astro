---
---

<div class="w-full bg-white py-12 border-y border-gray-100 overflow-hidden select-none">
  <div class="flex whitespace-nowrap animate-ticker">
    {Array(10).fill(0).map(() => (
      <div class="flex items-center gap-8 px-4">
        <span class="text-[40px] md:text-[64px] font-black text-gray-900 uppercase tracking-tighter">Logística</span>
        <span class="w-4 h-4 rounded-full bg-fenix-red-light"></span>
        <span class="text-[40px] md:text-[64px] font-black text-gray-900 uppercase tracking-tighter">Transporte</span>
        <span class="w-4 h-4 rounded-full bg-fenix-red-light"></span>
        <span class="text-[40px] md:text-[64px] font-black text-gray-900 uppercase tracking-tighter">Carga</span>
        <span class="w-4 h-4 rounded-full bg-fenix-red-light"></span>
        <span class="text-[40px] md:text-[64px] font-black text-gray-900 uppercase tracking-tighter">Aduana</span>
        <span class="w-4 h-4 rounded-full bg-fenix-red-light"></span>
      </div>
    ))}
  </div>
</div>

<style>
  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .animate-ticker {
    display: flex;
    width: fit-content;
    animation: ticker 80s linear infinite;
  }

  .animate-ticker:hover {
    animation-play-state: paused;
  }
</style>
