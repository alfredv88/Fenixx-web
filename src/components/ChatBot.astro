---

<div 
  id="persistent-chat" 
  class="fixed bottom-10 left-10 z-[60] flex flex-col-reverse items-center gap-4 transition-all duration-500 opacity-0 translate-y-10 pointer-events-none"
>
  <!-- Botón con gradiente corporativo (Naranja Claro a Naranja Oscuro) -->
  <button class="bg-gradient-to-br from-fenix-red-light to-fenix-red-dark p-4 rounded-full text-white shadow-xl hover:scale-110 transition-transform active:scale-95 shadow-fenix-red-dark/30">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-square-text"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M13 8H7"/><path d="M17 12H7"/></svg>
  </button>
  
  <!-- Cápsula con acento en Naranja Claro y borde gris corporativo -->
  <div class="bg-black/90 backdrop-blur-lg border border-[#808080]/30 px-5 py-2 rounded-full hidden sm:block shadow-2xl">
      <span class="text-white font-bold text-sm tracking-wide">Asesoría: <span class="text-fenix-red-light">En línea</span></span>
  </div>
</div>

<script>
  const chatWidget = document.getElementById('persistent-chat');
  
  window.addEventListener('scroll', () => {
    // Aparece después de scroll de 200px o al salir del hero
    if (window.scrollY > 400) {
      chatWidget?.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
      chatWidget?.classList.add('opacity-100', 'translate-y-0', 'pointer-events-all');
    } else {
      chatWidget?.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
      chatWidget?.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-all');
    }
  });
</script>
