---
const stats = [
  { number: "15+", label: "Años de experiencia", suffix: "" },
  { number: "50K", label: "Toneladas movidas", suffix: "+" },
  { number: "20", label: "Puertos conectados", suffix: "+" },
  { number: "200", label: "Clientes satisfechos", suffix: "+" },
];
---

<section class="py-24 md:py-32 bg-fenix-black relative overflow-hidden">

  <div class="w-full px-6 md:px-12 lg:px-24 relative z-10">

    <!-- Header -->
    <div class="text-center mb-16 md:mb-20">
      <span class="text-xs uppercase tracking-[0.3em] text-fenix-red-light font-bold block mb-4">
        En Números
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white tracking-tight">
        El pulso de su carga,<br/>
        <span class="text-fenix-red-light">la fuerza</span> de su éxito
      </h2>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
      {stats.map((stat) => (
        <div class="text-center group">
          <div class="mb-4">
            <span class="text-5xl md:text-6xl lg:text-7xl font-black text-fenix-red-light leading-none tracking-tight group-hover:scale-110 transition-transform duration-300 inline-block">
              {stat.number}
            </span>
          </div>
          <div class="w-12 h-[2px] bg-fenix-red-light/30 mx-auto mb-4"></div>
          <p class="text-white/60 text-sm md:text-base uppercase tracking-wider font-medium">
            {stat.label}
          </p>
        </div>
      ))}
    </div>

  </div>

  <!-- Decorative Line -->
  <div class="absolute bottom-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-fenix-red-light/30 to-transparent"></div>
</section>
