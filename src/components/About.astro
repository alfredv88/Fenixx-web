---
---

<section id="nosotros" class="py-24 md:py-32 bg-[#F5F5F0] relative overflow-hidden">
  
  <!-- Monumental Background Text -->
  <div class="absolute top-1/2 left-0 -translate-y-1/2 w-full select-none pointer-events-none overflow-hidden flex justify-center opacity-[0.03]">
    <span class="text-[20vw] font-black text-fenix-black uppercase tracking-tighter whitespace-nowrap leading-none">
      FENIXX
    </span>
  </div>

  <div class="w-full px-6 md:px-12 lg:px-24 relative z-10">

    <!-- Header -->
    <div class="mb-16">
      <span class="text-xs uppercase tracking-[0.3em] text-fenix-red-light font-bold block mb-4">
        Sobre Nosotros
      </span>
    </div>

    <!-- Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
      
      <!-- Left: Big Statement -->
      <div class="lg:col-span-7">
        <h2 class="text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-black text-fenix-black leading-[1] tracking-tight">
          <span class="text-gray-400 font-light block mb-2">Conectamos fronteras,</span> 
          simplificamos destinos
        </h2>
      </div>

      <!-- Right: Description + CTA -->
      <div class="lg:col-span-5 flex flex-col justify-end">
        <p class="text-gray-600 text-base md:text-lg leading-relaxed mb-8">
          En un mercado global que no se detiene, su empresa necesita un aliado que domine cada etapa 
          de la cadena de suministro. Somos su <span class="text-fenix-black font-bold">Centro Intermodal</span>, 
          especialistas en gestionar la complejidad logística para que usted se enfoque en hacer crecer 
          su negocio. Desde el origen hasta el destino final, movemos su éxito por cualquier vía.
        </p>
        <div>
          <a 
            href="/nosotros" 
            class="inline-flex items-center gap-3 bg-fenix-red-light hover:bg-fenix-red-dark text-white px-8 py-4 rounded-full font-bold transition-all duration-300 transform hover:scale-105"
          >
            Conocer más
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Promise Bar -->
    <div class="mt-20 pt-12 border-t border-black/5">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-full bg-fenix-red-light/10 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-fenix-red-light">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div>
            <h4 class="text-fenix-black font-bold text-lg mb-1">Seguridad</h4>
            <p class="text-gray-500 text-sm">Protección integral de su mercancía en cada eslabón.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-full bg-fenix-red-light/10 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-fenix-red-light">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <h4 class="text-fenix-black font-bold text-lg mb-1">Velocidad</h4>
            <p class="text-gray-500 text-sm">Tiempos optimizados para acelerar su operación.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-full bg-fenix-red-light/10 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-fenix-red-light">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <div>
            <h4 class="text-fenix-black font-bold text-lg mb-1">Eficiencia</h4>
            <p class="text-gray-500 text-sm">Gestión integral que garantiza resultados en cada movimiento.</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
