---
const services = [
  {
    title: "Transporte Multimodal",
    description: "Cobertura total en todas las modalidades: marítimo, aéreo, terrestre y gestión de fletes internacionales.",
    image: "/images/service-transporte.png",
    alt: "Servicios de transporte multimodal y flete marítimo, aéreo y terrestre",
    link: "/servicios/transporte"
  },
  {
    title: "Gestión Aduanera",
    description: "Simplificamos la burocracia para acelerar sus tiempos de entrega con asesoría y representación integral.",
    image: "/images/service-aduanas.png",
    alt: "Asesoría experta y representación en trámites de gestión aduanera internacional",
    link: "/servicios/aduanas"
  },
  {
    title: "Manejo de Carga",
    description: "Capacidad técnica para cualquier tipo de mercancía, desde bultos individuales hasta cargas sobredimensionadas.",
    image: "/images/service-carga.png",
    alt: "Logística y manejo especializado de carga sobredimensionada e industrial",
    link: "/servicios/carga"
  }
];
---

<section id="servicios" class="py-24 md:py-32 bg-[#F5F5F0] relative">
  <div class="w-full px-6 md:px-12 lg:px-24 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 lg:gap-12">
      
      <!-- Info Column -->
      <div class="flex flex-col justify-start lg:pr-6 mb-10 lg:mb-0">
        <span class="text-xs uppercase tracking-[0.3em] text-fenix-red-light font-bold block mb-4">
          Nuestros Servicios
        </span>
        <h2 class="text-4xl md:text-5xl font-black text-fenix-black tracking-tight mb-6">
          Logística <br/><span class="text-fenix-red-light">Integral</span>
        </h2>
        <p class="text-gray-600 text-base md:text-lg font-medium leading-relaxed mb-10">
          Movemos su carga de forma rápida, segura e inteligente para el éxito de su cadena de suministro.
        </p>
        <div>
          <a href="/servicios" class="inline-flex items-center gap-3 bg-fenix-red-light hover:bg-fenix-red-dark text-white px-8 py-4 rounded-full font-bold transition-all duration-300 transform hover:scale-105">
            Ver todas
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Services List (Web base replica) -->
      <div class="lg:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-10">
        {services.map((service) => (
          <a href={service.link} class="group flex flex-col cursor-pointer transition-transform duration-300 hover:-translate-y-2">
            <div class="w-full aspect-square md:aspect-[4/3] mb-6 overflow-hidden rounded-[2rem] shadow-none">
              <img 
                src={service.image} 
                alt={service.alt}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
            </div>
            <h3 class="text-2xl font-black text-fenix-black mb-3 tracking-tight group-hover:text-fenix-red-light transition-colors">
              {service.title}
            </h3>
            <p class="text-gray-600 text-base leading-relaxed">
              {service.description}
            </p>
          </a>
        ))}
      </div>

    </div>
  </div>
</section>
