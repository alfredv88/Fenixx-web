---
const currentYear = new Date().getFullYear();
---

<footer class="bg-fenix-black border-t border-white/5">
  <div class="w-full px-6 md:px-12 lg:px-24 py-12">

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <img src="/images/logo.png" alt="Fenixx Logo" class="h-20 w-auto object-contain mb-4" />
        <p class="text-white/40 text-sm leading-relaxed">
          El pulso de su carga, la fuerza de su éxito.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h5 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Navegación</h5>
        <ul class="space-y-3">
          <li><a href="#" class="text-white/40 text-sm hover:text-fenix-red-light transition-colors">Inicio</a></li>
          <li><a href="#servicios" class="text-white/40 text-sm hover:text-fenix-red-light transition-colors">Servicios</a></li>
          <li><a href="#nosotros" class="text-white/40 text-sm hover:text-fenix-red-light transition-colors">Quiénes Somos</a></li>
          <li><a href="#proyectos" class="text-white/40 text-sm hover:text-fenix-red-light transition-colors">Portafolio</a></li>
          <li><a href="#contacto" class="text-white/40 text-sm hover:text-fenix-red-light transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h5 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Servicios</h5>
        <ul class="space-y-3">
          <li><a href="/servicios/transporte" class="text-white/40 text-sm hover:text-fenix-red-light transition-colors">Transporte Multimodal</a></li>
          <li><a href="/servicios/aduanas" class="text-white/40 text-sm hover:text-fenix-red-light transition-colors">Gestión Aduanera</a></li>
          <li><a href="/servicios/carga" class="text-white/40 text-sm hover:text-fenix-red-light transition-colors">Manejo de Carga</a></li>
          <li><a href="/servicios/equipos" class="text-white/40 text-sm hover:text-fenix-red-light transition-colors">Alquiler de Equipos</a></li>
        </ul>
      </div>

      <!-- Contact Mini -->
      <div>
        <h5 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Contacto</h5>
        <ul class="space-y-3">
          <li class="text-white/40 text-sm leading-relaxed">
            Av. Raúl Leoni con Av. Real, Local S/N<br/>
            Urb. Industria de Guanta, Anzoátegui.
          </li>
          <li><a href="tel:+5804129671098" class="text-white/40 text-sm hover:text-fenix-red-light transition-colors">+58 0412 967 1098</a></li>
          <li><a href="mailto:info@fenixx.com" class="text-white/40 text-sm hover:text-fenix-red-light transition-colors">info@fenixx.com</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/30 text-xs">
        &copy; {currentYear} Fenixx Import Export C.A. Todos los derechos reservados.
      </p>
      <p class="text-white/20 text-xs">
        Diseñado por <a href="#" class="hover:text-fenix-red-light transition-colors">AMS Desarrollos</a>
      </p>
    </div>

  </div>
</footer>
