---
const projects = [
  {
    title: "Carga Marítima Internacional",
    category: "Transporte Multimodal",
    image: "/images/service-transporte.png"
  },
  {
    title: "Despacho Aduanero Express",
    category: "Gestión Aduanera",
    image: "/images/service-aduanas.png"
  },
  {
    title: "Izada de Equipos Pesados",
    category: "Manejo de Carga",
    image: "/images/service-carga.png"
  },
  {
    title: "Suministro de Maquinaria",
    category: "Alquiler de Equipos",
    image: "/images/service-maquinaria.png"
  }
];
---

<section id="proyectos" class="py-24 md:py-32 bg-[#F5F5F0]">
  <div class="w-full px-6 md:px-12 lg:px-24">

    <!-- Header -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16">
      <div class="lg:col-span-6">
        <span class="text-xs uppercase tracking-[0.3em] text-fenix-red-light font-bold block mb-4">
          Portafolio
        </span>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-fenix-black leading-[0.9] tracking-tight">
          Proyectos que<br/>
          <span class="text-fenix-red-light">hablan</span> por nosotros
        </h2>
      </div>
      <div class="lg:col-span-4 lg:col-start-9 flex items-end">
        <p class="text-fenix-gray text-base md:text-lg leading-relaxed">
          Cada operación es un compromiso. Estos son algunos de los proyectos que reflejan nuestra capacidad y experiencia.
        </p>
      </div>
    </div>

    <!-- Projects Grid: 2x2 -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <a href="#" class="group relative block overflow-hidden rounded-2xl h-72 md:h-96">
          <img 
            src={project.image} 
            alt={project.title}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
          />
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
          
          <!-- Content -->
          <div class="absolute bottom-0 left-0 w-full p-6 md:p-8">
            <span class="text-fenix-red-light text-xs uppercase tracking-widest font-bold mb-2 block">
              {project.category}
            </span>
            <h3 class="text-white text-xl md:text-2xl font-black group-hover:text-fenix-red-light transition-colors duration-300">
              {project.title}
            </h3>
          </div>

          <!-- Hover Arrow -->
          <div class="absolute top-6 right-6 w-12 h-12 rounded-full bg-white/10 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-4 group-hover:translate-y-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center">
      <a 
        href="/portafolio" 
        class="inline-flex items-center gap-3 border-2 border-fenix-black text-fenix-black px-10 py-4 rounded-full font-bold hover:bg-fenix-black hover:text-white transition-all duration-300"
      >
        Ver portafolio completo
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>
